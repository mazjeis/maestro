{% extends "projects/base.twig" %}

{% block content %}
    <form method="POST" action="/projects/{{ project.id }}/edit">
        <div class="card shadow-sm">
            <div class="card-header">
                <strong>Create a new project</strong>
            </div>

            <div class="card-body">
                {% if errors %}
                    <div class="row alert alert-danger">
                        <ul>
                            {% for error in errors %}
                                <li>{{ error }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold"><label for="title">Title</label></div>
                    <div class="col-sm-9"><input type="text" id="title" name="title" class="form-control" value="{{ project.title }}"></div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold"><label for="description">Description</label></div>
                    <div class="col-sm-9 text-break"><textarea id="description" name="description" class="form-control">{{ project.description }}</textarea></div>
                </div>
            </div>

            <div class="card-footer d-flex gap-2">
                <input type="submit" value="Update" class="btn btn-primary">
            </div>
        </div>
    </form>
    <form method="POST" action="/projects/{{ project.id }}/delete" onsubmit="return confirm('Are you sure you want to delete this project?');">
        <input type="submit" value="Delete Project" class="btn btn-danger">
    </form>
{% endblock %}